(let fib_iter (lambda (pair n) (
    if (= n 0)
    pair
    (fib_iter (list (get pair 1) (+ (get pair 0) (get pair 1))) (- n 1))
)))

(let fib (lambda (n) (get (fib_iter (list 0 1) n) 0)))

(print (fib 1))
(print (fib 2))
(print (fib 3))
(print (fib 4))
(print (fib 5))
(print (fib 6))
(print (fib 30))
