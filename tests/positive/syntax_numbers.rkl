; Every literal form the syntax defines, and the same text through int and
; float, which read it with the very same scanner.

; Integers, decimal and by radix.
(print "dec   $0 $1 $2" 42 -7 +3)                    ; 42 -7 3
(print "bin   $0 $1" 0b1010 -0b101)                  ; 10 -5
(print "oct   $0" 0o17)                              ; 15
(print "hex   $0 $1" 0xFF 0xff)                      ; 255 255
(print "int?  $0 $1" (?INTEGER 0xFF) (?INTEGER -7))  ; True True

; Floats: with a point on either side, and with an exponent.
(print "point $0 $1" 3.14 -0.5)                      ; 3.140000 -0.500000
(print "lead  $0 $1" .25 -.5)                        ; 0.250000 -0.500000
(print "trail $0" 1.)                                ; 1.000000
(print "exp   $0 $1 $2" 1e10 1.5e-3 .5E+2)           ; 10000000000.000000 0.001500 50.000000
(print "float? $0 $1" (?FLOAT .25) (?FLOAT 1e10))    ; True True

; An integer mantissa with an exponent is a Float, since the value needs one.
(print "expkind $0" (?FLOAT 1e3))                    ; True

; The same forms read out of strings.
(print "cast-radix $0 $1 $2" (int "0b1010") (int "0o17") (int "0xFF"))  ; 10 15 255
(print "cast-lead  $0 $1" (float ".25") (float "-.5"))                  ; 0.250000 -0.500000
(print "cast-exp   $0 $1" (float "1.5e-3") (float ".5E+2"))             ; 0.001500 50.000000
(print "agree      $0 $1" (= (float ".25") .25) (= (int "0xFF") 0xFF))  ; True True

; A point with no digit on either side is still the symbol it always was, and a
; prefix with no digits after it is not a radix literal.
(print "dot-symbol $0" (?SYMBOL '.))                 ; True
(print "name-dot   $0" (?SYMBOL 'a.b))               ; True

; Text the reader would not take whole is rejected rather than half-read.
(print "reject $0 $1 $2" (try VALUE_EXCEPTION (int "12x"))
                         (try VALUE_EXCEPTION (int " 12"))
                         (try VALUE_EXCEPTION (float "")))
