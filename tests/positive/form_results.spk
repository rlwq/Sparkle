; Every form is an expression: it yields the last value it produced, and Nil
; when it produced none.

(print "let-one=$0" (let a 42))              ; let-one=42
(print "let-many=$0" (let b 1 c (+ b 1)))    ; let-many=2
(print "let-none=$0" (let))                  ; let-none=Nil

(print "set=$0" (set a 7))                   ; set=7

; A loop whose body never runs has no value to give back.
(print "while-skipped=$0" (while False 1))   ; while-skipped=Nil
(let i 0)
(print "while-ran=$0"
  (while (< i 3) (begin (set i (+ i 1)) (* i 10))))   ; while-ran=30

(print "for-empty=$0" (for v '() v))      ; for-empty=Nil
(print "for-last=$0" (for v '(1 2 3) (* v 100)))  ; for-last=300
(print "for-nobody=$0" (for v '(1 2)))    ; for-nobody=Nil

; With several body expressions the last one wins, on the last iteration.
(print "for-multi=$0" (for v '(1 2) (* v 10) (* v 100)))  ; for-multi=200
(print "for-keyed=$0" (for (k v) '("a" "b") k))          ; for-keyed=1

(print "begin=$0" (begin 1 2 99))            ; begin=99
(print "if=$0" (if True 5))                  ; if=5
(print "if-nobranch=$0" (if False 5))        ; if-nobranch=Nil
(print "try=$0" (try TYPE_EXCEPTION 1 2 42)) ; try=42

; The result of a loop is usable like any other value.
(let total (for v '(1 2 3) (* v v)))
(print "usable=$0" total)                    ; usable=9
