; map/filter must not re-evaluate the elements they pass to the callback
(print "$0" (map (lambda (x) x) (list (list 1 2) (list 3 4))))
(print "$0" (map (lambda (x) x) (list "a" "b")))
(print "$0" (map (lambda (x) (len x)) (list (list 1) (list 1 2) (list))))
(print "$0" (map (lambda (x) x) (list)))
(print "$0" (filter (lambda (x) (> (len x) 1)) (list (list 1 2) (list 3) (list 4 5))))
(print "$0" (filter (lambda (x) x) (list (list) (list 1) "" "x")))
