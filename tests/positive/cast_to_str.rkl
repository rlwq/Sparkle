; str casts any object to its printed representation
(print "$0" (str 42))
(print "$0" (str -7))
(print "$0" (str 3.5))
(print "$0" (str True))
(print "$0" (str False))
(print "$0" (str Nil))
(print "$0" (str Symbol))

; A string is returned unchanged
(print "$0" (str "already a string"))
(print "$0" (str ""))

; Composites mirror print
(print "$0" (str '(1 "two" 3.5)))
(print "$0" (str '()))

; The result is a real string
(print "$0" (?STRING (str 42)))
(print "$0" (str-len (str 1000)))
(print "$0" (str-cat "n = " (str 42)))
(print "$0" (str-sub (str 12345) 1 3))
