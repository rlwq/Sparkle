; str-len
(print "$0" (str-len "hello"))
(print "$0" (str-len ""))

; str-get
(print "$0" (str-get "hello" 0))
(print "$0" (str-get "hello" 4))

; str-sub
(print "$0" (str-sub "hello world" 6 5))
(print "$0" (str-sub "abc" 0 3))
(print "$0" (str-len (str-sub "abc" 1 0)))

; str-cat
(print "$0" (str-cat "foo" "-" "bar"))
(print "$0" (str-len (str-cat)))
(print "$0" (= (str-cat "ab" "c") "abc"))

; str-find
(print "$0" (str-find "hello" "llo"))
(print "$0" (str-find "hello" "hello"))
(print "$0" (str-find "hello" "x"))
(print "$0" (str-find "hello" ""))

; str-ord / str-chr
(print "$0" (str-ord "A"))
(print "$0" (str-chr 66))
(print "$0" (str-ord (str-chr 97)))

; composition with lists
(print "$0" (map str-len '("a" "bb" "ccc")))
(let shout (lambda (s) (str-cat s "!")))
(print "$0" (shout "wow"))

; results are real strings: GC-owned, comparable, truthy rules apply
(print "$0" (if (str-sub "abc" 0 0) "truthy" "falsy"))
(print "$0" (if (str-cat "a" "") "truthy" "falsy"))
