; not, and the two shapes of conjunction: && and || are ordinary functions, so
; every argument is evaluated; and and or are special forms that stop as soon
; as the answer is settled. Both cast their arguments with the ? rule.

(print "not      $0 $1 $2" (not True) (not 0) (not "x"))   ; False True False

(print "and-fn   $0 $1 $2" (&& 1 2) (&& 1 0) (&&))         ; True False True
(print "or-fn    $0 $1 $2" (|| 0 1) (|| 0 0) (||))         ; True False False

(print "and-form $0 $1" (and 1 2) (and 1 0))               ; True False
(print "or-form  $0 $1" (or 0 1) (or 0 0))                 ; True False

; Short-circuiting is observable: the marker only changes if the form kept
; going past the point where the answer was already known.
(let reached 0)
(and False (set reached 1))
(print "and-stopped $0" reached)                           ; 0

(set reached 0)
(or True (set reached 1))
(print "or-stopped  $0" reached)                           ; 0

; The function forms have no such shortcut - both arguments are evaluated
; before the call happens at all.
(set reached 0)
(&& False (set reached 1))
(print "and-fn-ran  $0" reached)                           ; 1

(set reached 0)
(|| True (set reached 1))
(print "or-fn-ran   $0" reached)                           ; 1

; Empty arguments follow the identity of each operation.
(print "identities $0 $1" (and) (or))                      ; True False
