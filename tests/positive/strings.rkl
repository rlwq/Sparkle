; String literals
(print "hello")
(print "with spaces here")

; Escape sequences
(print "line1\nline2")
(print "say \"hi\"")
(print "tab\tend")
(print "back\\slash")
(print "\x41\x42\x43")

; Equality is by content
(print "$0" (= "abc" "abc"))
(print "$0" (= "abc" "abd"))
(print "$0" (= "abc" "abcd"))
(print "$0" (= "" ""))
(print "$0" (= "abc" 42))

; Truthiness: empty string is falsy
(print "$0" (if "" 1 2))
(print "$0" (if "x" 1 2))
(print "$0" (not ""))

; Type predicate
(print "$0" (?STRING "s"))
(print "$0" (?STRING 5))

; Strings are first-class values
(let s "stored")
(print "$0" s)
(let id (lambda (x) x))
(print "$0" (id "through lambda"))
(print "$0" '("in" "list" 1))
