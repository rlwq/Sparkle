; quote hands back its argument unevaluated; 'x is the same thing written short.
(print "form  $0" (quote (+ 1 2)))              ; (+ 1 2)
(print "short $0" '(+ 1 2))                     ; (+ 1 2)
(print "same  $0" (= (len '(+ 1 2)) (len (quote (+ 1 2)))))  ; True

; A quoted symbol is a Symbol value, not a lookup.
(let y 11)
(print "symbol $0 $1" 'y y)                     ; y 11
(print "kind   $0 $1" (?SYMBOL 'y) (?INTEGER y))  ; True True

; Quoting nests, and the inner quote survives as data.
(print "nested $0" ''x)                         ; 'x
(print "inner  $0" (?LIST ''x))                 ; True

; Quoted data is an ordinary list: it can be measured and indexed.
(let expr '(+ 10 20))
(print "parts  $0 $1 $2" (len expr) (get expr 0) (get expr 1))  ; 3 + 10

; Self-evaluating values are unaffected by quoting.
(print "atoms  $0 $1 $2" '42 (quote "s") (= '5 5))  ; 42 s True

; eval turns quoted data back into a result.
(print "eval   $0 $1" (eval expr) (eval '(quote inner)))  ; 30 inner
