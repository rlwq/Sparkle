; Arithmetic
(print "$0" ARITHMETICS)
(print "$0" (+ 1 2 3))        ; 6
(print "$0" (* 2 3 4))        ; 24
(print "$0" (- 10 3 2))       ; 5
(print "$0" (/ 7 2))          ; 3.5
(print "$0" (div 7 2))        ; 3
(print "$0" (mod 7 2))        ; 1

; Mixed numeric types
(print "$0" MIXED_TYPES)
(print "$0" (+ 1 (/ 3 2)))    ; 2.5
(print "$0" (* 2 True))       ; 2
(print "$0" (= 1 True))       ; True
(print "$0" (= 0 False))      ; True
(print "$0" (= 1 (/ 1 1)))    ; True

; Equality
(print "$0" EQUALITY)
(print "$0" (= 1 1))          ; True
(print "$0" (= 1 2))          ; False
(print "$0" (!= 1 2))         ; True
(print "$0" (!= 1 1))         ; False
(print "$0" (= Nil Nil))      ; True

; Ordering
(print "$0" ORDERING)
(print "$0" (> 3 2))          ; True
(print "$0" (> 1 4))          ; False
(print "$0" (< 2 3))          ; True
(print "$0" (< 10 1))         ; False
(print "$0" (>= 3 3))         ; True
(print "$0" (>= 3 2))         ; True
(print "$0" (>= 2 3))         ; False
(print "$0" (<= 5 5))         ; True
(print "$0" (<= 1 5))         ; True
(print "$0" (<= 5 1))         ; False

; eval, nil?
(print "$0" NIL?)
(print "$0" (eval '(+ 1 2)))  ; 3
(print "$0" (nil? Nil))       ; True
(print "$0" (nil? 1))         ; False
