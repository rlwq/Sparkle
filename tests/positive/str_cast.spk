; str renders any value exactly as print would show it.
(print "num   $0 $1 $2" (str 42) (str -7) (str 3.5))        ; 42 -7 3.500000
(print "bool  $0 $1" (str True) (str False))                ; True False
(print "nil   $0" (str Nil))                                ; Nil
(print "sym   $0" (str 'Symbol))                            ; Symbol
(print "list  $0 $1" (str '(1 "two" 3.5)) (str '()))        ; (1 two 3.500000) ()

; A string passes through unchanged.
(print "ident $0 $1" (str "already") (str-len (str "")))    ; already 0

; The result is a real String, usable everywhere one is.
(print "kind  $0" (?STRING (str 42)))                       ; True
(print "len   $0" (str-len (str 1000)))                     ; 4
(print "cat   $0" (str-cat "n = " (str 42)))                ; n = 42
(print "sub   $0" (str-sub (str 12345) 1 3))                ; 234
