(let x 17
     y 49)

(print "$0" (set x 2))              ; 2

(print "$0" (set y x                ; y = 2
             x (+ x y)))       ; x = 51 (uses pre-assignment x and y)

(print "$0" x)                      ; 51
(print "$0" y)                      ; 2

(let a 1 b 2)
(set a b b a)                  ; simultaneous swap
(print "$0" a)                      ; 2
(print "$0" b)                      ; 1
