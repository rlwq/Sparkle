/* a block comment before any code */
(print 1)

(print /* inline between tokens */ 2)

/* spanning
   several
   lines */
(print 3)

(print (+ 1 /* even between arguments */ 2))

; a line comment still works: /* this opener is dead inside it
(print "/* not a comment inside a string */")

/* division is untouched */
(print (/ 6 4))

/* comments /* nest: /* every */ inner */ opener needs its own closer */
(print 4)

/* adjacent markers /**/ /* */ also fine */
(print 5)
