(print "eq    $0 $1 $2" (= 1 1) (= 1 2) (!= 1 2))          ; True False True
(print "order $0 $1 $2 $3" (< 2 3) (> 3 2) (<= 3 3) (>= 2 3))  ; True True True False

; Numbers compare across Integer and Float, and Bool counts as 1 or 0.
(print "cross $0 $1 $2" (= 1 1.0) (= 1 True) (= 0 False))  ; True True True
(print "mixord $0 $1" (< 1 1.5) (>= 2.0 2))                ; True True

; Strings compare by content.
(print "str   $0 $1 $2" (= "abc" "abc") (= "abc" "abd") (= "abc" "abcd"))  ; True False False
(print "empty $0" (= "" ""))                               ; True

; Nil equals only Nil.
(print "nil   $0 $1" (= Nil Nil) (= Nil 0))                ; True False

; Comparing across unrelated kinds is False rather than an error.
(print "kinds $0 $1" (= "abc" 42) (= 'sym "sym"))          ; False False

; Lists compare structurally: same length and equal elements, each by its own
; rule. Lambdas and builtins still compare by identity.
(let xs '(1 2))
(print "ident  $0 $1" (= xs xs) (= '(1 2) '(1 2)))         ; True True
(print "struct $0 $1 $2" (= '(1 2) '(1 3)) (= '(1) '(1 2)) (= '() '()))     ; False False True
(print "nested $0 $1" (= '(1 (2 3)) '(1 (2 3))) (= '(1 (2 3)) '(1 (2 4))))  ; True False
(print "elem   $0" (= '(1 2) '(1.0 2.0)))                  ; True - Integer and Float elements coerce

; Symbols compare by name, so equal spelling is equal value.
(print "sym   $0 $1" (= 'a 'a) (= 'a 'b))                  ; True False
