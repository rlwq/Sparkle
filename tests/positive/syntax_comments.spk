/* a block comment before any code */
(print "$0" 1)                                  ; 1

(print "$0" /* between tokens */ 2)             ; 2

/* spanning
   several
   lines */
(print "$0" 3)                                  ; 3

(print "$0" (+ 1 /* between arguments */ 2))    ; 3

; a line comment: /* this opener is dead inside it
(print "/* not a comment inside a string */")

/* comments /* nest: /* every */ inner */ opener needs its own closer */
(print "$0" 4)                                  ; 4

/* adjacent markers /**/ /* */ also fine */
(print "$0" 5)                                  ; 5

(print "$0" 6) ; trailing line comment
