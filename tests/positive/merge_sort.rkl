(let split
  (lambda (l)
    (begin
      (let l1 Nil)
      (let l2 Nil)
      (while l
             (begin
               (set l1 (cons (car l) l1))
               (set l (cdr l))
               (if l
                 (begin
                   (set l2 (cons (car l) l2))
                   (set l (cdr l))))))
      (cons l1 l2))))

(let merge
  (lambda (l1 l2)
  (if l1
    (if l2
      (if (< (car l1) (car l2))
        (cons (car l1) (merge (cdr l1) l2))
        (cons (car l2) (merge l1 (cdr l2))))
      l1)
    l2)))

(let merge_sort
  (lambda (l)
    (if l
      (if (cdr l)
        (begin
          (let splitted (split l))
          (let sorted_left (merge_sort (car splitted)))
          (let sorted_right (merge_sort (cdr splitted)))
          (merge sorted_left sorted_right)
          ) l)
      l)))

